# Redis (BullMQ broker)
REDIS_URL=redis://localhost:6379

# Go HTML→Markdown service
GO_MD_SERVICE_URL=http://localhost:3001

# Python LLM service
PYTHON_LLM_URL=http://localhost:3002

# Abrasio (Layer 3 - stealth engine via abrasio-sdk)
#
# Cloud mode (paid):  set ABRASIO_API_KEY=sk_...
#   → managed browser session via Abrasio API + CDP
#
# Local mode (free):  set ABRASIO_API_URL=local
#   → Patchright with full fingerprint patches running locally
#   → extra stealth vs Layer 2 (canvas noise, audio noise, WebGL spoofing)
#
# Leave both empty to disable Layer 3 entirely (open-source mode)
ABRASIO_API_URL=
ABRASIO_API_KEY=

# LLM (for extract/deep-research tasks)
GENAI_API_KEY=your api key here

# Proxy (optional)
# Country code is inferred from the target URL's TLD and appended to PROXY_USERNAME at runtime.
# Example (Massive): PROXY_URL=http://yourproxy.com:1234
#                    PROXY_USERNAME=myuser-country-   ← country code appended, e.g. "myuser-country-BR"
#                    PROXY_PASSWORD=yourpassword
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Health-check HTTP server port (0 = disabled)
HEALTH_PORT=3003

# Bull Board dashboard port
DASHBOARD_PORT=5555
# Set to "false" to disable the dashboard
# ENABLE_DASHBOARD=false

# Browser mode — set to "false" to open a visible browser window (local dev only)
HEADLESS=true

# Scraping defaults
DEFAULT_TIMEOUT=60
MAX_CONCURRENT_PAGES=10
MAX_CRAWL_DEPTH=5
MAX_CRAWL_URLS=1000
